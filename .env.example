# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# MongoDB Atlas Connection URI (e.g. mongodb+srv://username:password@cluster.mongodb.net/database_name)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/sahp_bot

# Hata ayıklama ve günlük log seviyesi (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Discord Channel IDs
# Aktif Mesai ses kanalı ID'si
AKTIF_MESAI_CHANNEL_ID=123456789012345678

# Mesai loglarının (Giriş uyarısı ve çıkış özeti butonunun) gönderileceği kanal ID'si
MESAI_LOG_CHANNEL_ID=123456789012345678

# Mazeret butonunun bulunacağı yazı kanalı ID'si
MAZERET_CHANNEL_ID=123456789012345678

# Gelen mazeretlerin iletileceği yazı kanalı ID'si
GELEN_MAZERET_CHANNEL_ID=123456789012345678

# Opsiyonel: Komutların hızlı senkronize edilmesi için sunucu ID'si (Hızlı test/kurulum için önerilir)
GUILD_ID=123456789012345678
